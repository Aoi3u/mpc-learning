def compare_swap(a, b):
    swap = a > b
    small = swap.if_else(b, a)
    large = swap.if_else(a, b)
    return small, large

a = sint(1)
b = sint(2)
small, large = compare_swap(a, b)
print_ln('%s %s', small.reveal(), large.reveal()) # 1 2

a = sint(5)
b = sint(5)
small, large = compare_swap(a, b)
print_ln('%s %s', small.reveal(), large.reveal())