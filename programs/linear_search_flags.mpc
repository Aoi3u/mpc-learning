def linear_search(arr, target):
    result = Array(len(arr), sint)

    @for_range(len(arr))
    def f(i):
        result[i] = (arr[i] == target).if_else(1, 0)
    
    return result

arr = Array(5, sint)
arr[0] = sint(9)
arr[1] = sint(2)
arr[2] = sint(4)
arr[3] = sint(4)
arr[4] = sint(0)

target = sint(4)
result = linear_search(arr, target)

@for_range(len(arr))
def f(i):
    print_ln('%s', result[i].reveal())